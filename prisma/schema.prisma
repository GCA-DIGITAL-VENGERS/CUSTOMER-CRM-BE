generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Client {
  id            String   @id @default(uuid())
  nombre        String
  email         String   @unique
  telefono      String
  empresa       String
  estado        String   @default("ACTIVO")
  contacts      Contact[]
  opportunities Opportunity[]
  activities    Activity[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("clients")
}

model Contact {
  id        String   @id @default(uuid())
  clienteId String
  cliente   Client   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  nombre    String
  cargo     String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clienteId, email])
  @@map("contacts")
}

model Opportunity {
  id          String   @id @default(uuid())
  clienteId   String
  cliente     Client   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  titulo      String
  valor       Float
  etapa       String   @default("PROSPECCION")
  fechaCierre DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("opportunities")
}

model Activity {
  id          String   @id @default(uuid())
  clienteId   String
  cliente     Client   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tipo        String
  descripcion String
  fecha       DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("activities")
}

model ChatConversation {
  id        String   @id @default(uuid())
  messages  ChatMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_conversations")
}

model ChatMessage {
  id             String   @id @default(uuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String   @default("user")
  content        String   @db.Text
  createdAt      DateTime @default(now())

  @@map("chat_messages")
}
